
# ============================================================================
# TRADING BOT CONFIGURATION
# ============================================================================
# Fill in values marked REQUIRED. Everything else has sensible defaults.
# Viper maps these to config keys: SECTION_KEY -> section.key
#   e.g. DATABASE_HOST -> database.host
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE (PostgreSQL + TimescaleDB)
# ----------------------------------------------------------------------------
# Used by: docker-compose (postgres container) + go-bot (viper config)
# Default works for local Docker — change for remote/production DB
POSTGRES_USER=trading_bot
POSTGRES_PASSWORD=trading_bot_secret
POSTGRES_DB=trading_bot
POSTGRES_PORT=5432

# These are read by viper via SetEnvKeyReplacer (DATABASE_HOST -> database.host)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=trading_bot
DATABASE_PASSWORD=trading_bot_secret
DATABASE_NAME=trading_bot
DATABASE_SSLMODE=disable

# ----------------------------------------------------------------------------
# REDIS
# ----------------------------------------------------------------------------
# Used by: docker-compose (redis container) + go-bot
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0

# ----------------------------------------------------------------------------
# SECURITY [REQUIRED]
# ----------------------------------------------------------------------------
# Encrypts all user API keys at rest. Back this up — if lost, all stored keys are unrecoverable.
# Generate: openssl rand -base64 32
SECURITY_MASTER_KEY=

# ----------------------------------------------------------------------------
# TELEGRAM [REQUIRED — at least one bot token needed]
# ----------------------------------------------------------------------------
# 1. Open Telegram, message @BotFather
# 2. Send /newbot, follow prompts
# 3. Copy the token (format: 7123456789:AAH...)
TELEGRAM_BOT_TOKEN=
# Optional: your numeric Telegram chat ID for watchdog/reconciliation alerts.
TELEGRAM_ADMIN_CHAT_ID=0

# ----------------------------------------------------------------------------
# DISCORD [optional — alternative to Telegram]
# ----------------------------------------------------------------------------
# 1. Go to https://discord.com/developers/applications
# 2. New Application → Bot → Reset Token → copy token
# 3. Application ID is on the General Information page
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# ----------------------------------------------------------------------------
# WHATSAPP [optional — notifications only]
# ----------------------------------------------------------------------------
# 1. Go to https://developers.facebook.com
# 2. Create App → Business type → Add WhatsApp product
# 3. WhatsApp → API Setup → copy Phone Number ID and Access Token
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ----------------------------------------------------------------------------
# BINANCE
# ----------------------------------------------------------------------------
# testnet=true uses fake money — safe for testing
# Individual users register their own API keys via the Telegram/Discord bot
BINANCE_TESTNET=true
BINANCE_TESTNET_API_URL=https://testnet.binance.vision
BINANCE_TESTNET_WS_URL=wss://testnet.binance.vision/ws
BINANCE_MAINNET_API_URL=https://api.binance.com
BINANCE_MAINNET_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_FUTURES_TESTNET_API_URL=https://testnet.binancefuture.com
BINANCE_FUTURES_MAINNET_API_URL=https://fapi.binance.com

# ----------------------------------------------------------------------------
# CLAUDE AI [REQUIRED]
# ----------------------------------------------------------------------------
# 1. Go to https://console.anthropic.com
# 2. Settings → API Keys → Create Key
# 3. Copy key (format: sk-ant-api03-...)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# ----------------------------------------------------------------------------
# RUST ENGINE (gRPC technical indicators)
# ----------------------------------------------------------------------------
# Address where the Rust gRPC server listens
# Docker: rust-engine:50051 | Local: localhost:50051
RUST_ENGINE_ADDRESS=localhost:50051

# ----------------------------------------------------------------------------
# ML SERVICE (Python LSTM + sentiment)
# ----------------------------------------------------------------------------
# URL for the Python ML service
# Docker: http://ml-service:8000 | Local: http://localhost:8000
ML_SERVICE_BASE_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# ALTERNATIVE DATA SOURCES [optional — enriches AI analysis]
# ----------------------------------------------------------------------------
# CryptoPanic — crypto news aggregator
# 1. Go to https://cryptopanic.com/developers/api/
# 2. Sign up (free tier available) → copy Auth Token
DATASOURCES_CRYPTOPANIC_TOKEN=

# CoinGlass — derivatives & on-chain data
# 1. Go to https://www.coinglass.com/pricing
# 2. Sign up → API → copy API key
DATASOURCES_COINGLASS_API_KEY=

# CoinGecko — market data & community stats
# Optional: empty = free tier (rate-limited). Pro key removes limits.
# 1. Go to https://www.coingecko.com/en/api/pricing
# 2. Sign up for Demo/Pro → copy API key
DATASOURCES_COINGECKO_API_KEY=

# ----------------------------------------------------------------------------
# ANALYTICS REST API [optional]
# ----------------------------------------------------------------------------
# Exposes /api/positions, /api/trades, /api/decisions, /api/stats, /api/candles
API_ENABLED=true
API_KEY=
API_PORT=0

# ----------------------------------------------------------------------------
# TRADING SETTINGS
# ----------------------------------------------------------------------------
TRADING_DEFAULT_CONFIDENCE_THRESHOLD=80
TRADING_MAX_DAILY_NOTIFICATIONS=10
TRADING_SCANNER_INTERVAL_MINUTES=5
TRADING_OPPORTUNITY_EXPIRY_MINUTES=15
TRADING_TIMEFRAMES=4h,1d
TRADING_DRIFT_CHECK_INTERVAL_MINUTES=60

# ----------------------------------------------------------------------------
# LEVERAGE SETTINGS
# ----------------------------------------------------------------------------
LEVERAGE_HARD_MAX_LEVERAGE=20
LEVERAGE_MAX_MARGIN_PER_TRADE=500
LEVERAGE_LIQUIDATION_WARNING_PCT=10
LEVERAGE_LIQUIDATION_CRITICAL_PCT=5
LEVERAGE_LIQUIDATION_AUTO_CLOSE_PCT=2
LEVERAGE_MONITOR_INTERVAL_SECONDS=30

# ----------------------------------------------------------------------------
# SERVICE PORTS (docker-compose)
# ----------------------------------------------------------------------------
GO_BOT_PORT=8080
RUST_GRPC_PORT=50051
ML_SERVICE_PORT=8000

# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------
LOG_LEVEL=info
RUST_LOG=info
