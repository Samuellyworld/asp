{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Trades Total (by executor)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(trading_bot_trades_total[5m])",
          "legendFormat": "{{executor}} {{direction}} {{status}}"
        }
      ]
    },
    {
      "title": "Open Positions",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "trading_bot_open_positions",
          "legendFormat": "{{executor}}"
        }
      ]
    },
    {
      "title": "Trade PnL Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "trading_bot_trade_pnl_pct_bucket",
          "legendFormat": "{{executor}}"
        }
      ]
    },
    {
      "title": "Claude API Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(trading_bot_claude_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(trading_bot_claude_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "title": "DB Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(trading_bot_db_errors_total[5m])",
          "legendFormat": "errors/s"
        }
      ]
    },
    {
      "title": "Infrastructure Alerts",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "trading_bot_infra_alerts_total",
          "legendFormat": "{{service}} {{type}}"
        }
      ]
    },
    {
      "title": "Candles Ingested Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rate(trading_bot_candles_ingested_total[5m])",
          "legendFormat": "{{interval}}"
        }
      ]
    },
    {
      "title": "Notifications Sent",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "increase(trading_bot_notifications_sent_total[1h])",
          "legendFormat": "{{channel}} {{status}}"
        }
      ]
    },
    {
      "title": "Slippage (bps)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(trading_bot_slippage_bps_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(trading_bot_slippage_bps_bucket[5m]))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "trading_bot_circuit_breaker_state",
          "legendFormat": "{{breaker}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "OPEN", "color": "red" } } }
          ]
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["trading-bot"],
  "templating": { "list": [] },
  "title": "Trading Bot Overview",
  "uid": "trading-bot-overview",
  "version": 1
}
